# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/poi_game

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App
SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# POI search
POI_SEARCH_RADIUS_METERS=500
POI_MAX_CANDIDATES=15

# H3 hexagon grid
H3_RESOLUTION=9
USE_H3_DEDUP=false
