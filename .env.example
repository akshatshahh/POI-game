# Environment: use "production" to enforce strong secrets and hide OpenAPI docs
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/poi_game

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App
SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# POI search (values here mirror the code defaults in backend/app/config.py;
# whatever you set in .env overrides those defaults)
POI_SEARCH_RADIUS_METERS=150
POI_MAX_CANDIDATES=12

# H3 hexagon grid
H3_RESOLUTION=9
USE_H3_DEDUP=true

# Consensus policy: questions collect CONSENSUS_BASE_TARGET independent
# answers; on disagreement or in dense areas (>= DENSE_CANDIDATE_THRESHOLD
# nearby POIs) the target escalates to CONSENSUS_MAX_TARGET before the
# label is finalized and locked.
CONSENSUS_BASE_TARGET=3
CONSENSUS_MAX_TARGET=5
DENSE_CANDIDATE_THRESHOLD=12
# Answers from accounts younger than this many minutes don't count toward
# consensus (Sybil gate). 0 disables; 60 recommended in production.
CONSENSUS_MIN_ACCOUNT_AGE_MINUTES=0

# Only offer GPS probes inside the Greater Los Angeles bbox (see app/regions.py)
RESTRICT_GPS_TO_LA=true
